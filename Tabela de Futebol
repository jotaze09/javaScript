function adicionarTimeSeNaoExistir(nomeTime, escudoTime='⚽', fotoTime=null){
  if(!nomeTime || nomeTime.trim() === '') return null;
  
  // Verifica se time já existe
  let time = dados.times.find(t => t.nome === nomeTime.trim());
  
  if(!time){
    // Cria novo time
    time = {
      id: nextTimeId++,
      escudo: escudoTime,
      foto: fotoTime, // Nova propriedade para URL da foto
      nome: nomeTime.trim(),
      j:0, v:0, e:0, d:0, gm:0, gs:0, ult5:['','','','',''],
      melhor:'-'
    };
    dados.times.push(time);
    console.log(`➕ Time adicionado automaticamente: ${time.nome}`);
  }
  
  return time;
}

function sincronizarTimesComPartidas(){
  console.log('🔄 Sincronizando times com partidas...');
  
  // Coleta todos os times únicos das partidas
  const timesDasPartidas = new Set();
  dados.partidas.forEach(p => {
    if(p.mandante) timesDasPartidas.add(p.mandante.trim());
    if(p.visitante) timesDasPartidas.add(p.visitante.trim());
  });
  
  console.log(`📋 Times encontrados nas partidas: ${Array.from(timesDasPartidas).join(', ')}`);
  
  // Adiciona times que não existem
  timesDasPartidas.forEach(nomeTime => {
    adicionarTimeSeNaoExistir(nomeTime);
  });
  
  // Remove times que não estão em nenhuma partida
  const timesParaRemover = dados.times.filter(t => !timesDasPartidas.has(t.nome));
  timesParaRemover.forEach(t => {
    console.log(`🗑️ Removendo time que não está em partidas: ${t.nome}`);
    dados.times = dados.times.filter(time => time.id !== t.id);
  });
  
  console.log(`✅ Sincronização concluída. Total de times: ${dados.times.length}`);
}

/* ================================================================
   AUTO-CLASSIFICAÇÃO PELAS PARTIDAS - VERSÃO 2.0
   Recalcula TUDO baseado APENAS nas partidas com status "Encerrado"
================================================================ */
function recalcularClassificacaoPorPartidas(){
  console.log('🔄 Recalculando classificação...');
  
  // 1. Sincroniza times com as partidas primeiro
  sincronizarTimesComPartidas();
  
  // 2. Zera TODAS as estatísticas de todos os times
  dados.times.forEach(t=>{
    t.j=0; t.v=0; t.e=0; t.d=0; t.gm=0; t.gs=0; t.pts=0; t.sg=0;
    t.ult5=['','','','',''];
    console.log(`⚪ Zerando time: ${t.nome}`);
  });

  // 3. Processa TODAS as partidas (não apenas encerradas)
  const todasPartidas = dados.partidas;
  console.log(`📊 Total de partidas encontradas: ${todasPartidas.length}`);
  
  // 4. Ordena por data para histórico correto
  todasPartidas.sort((a,b)=>(a.data||'').localeCompare(b.data||'')||(a.id-b.id));

  // 5. Processa cada partida (independente do status)
  todasPartidas.forEach(p=>{
    const tm = dados.times.find(t=>t.nome===p.mandante);
    const tv = dados.times.find(t=>t.nome===p.visitante);
    const gm = parseInt(p.golsMandante)||0;
    const gv = parseInt(p.golsVisitante)||0;
    
    console.log(`⚽ Processando: ${p.mandante} ${gm}×${gv} ${p.visitante}`);

    // Time mandante
    if(tm){
      tm.j++; tm.gm+=gm; tm.gs+=gv;
      if(gm>gv){tm.v++;tm.ult5.push('v');}
      else if(gm===gv){tm.e++;tm.ult5.push('e');}
      else{tm.d++;tm.ult5.push('d');}
      console.log(`  ✅ Mandante ${tm.nome}: J=${tm.j} V=${tm.v} E=${tm.e} D=${tm.d} GM=${tm.gm} GS=${tm.gs}`);
    }
    
    // Time visitante
    if(tv){
      tv.j++; tv.gm+=gv; tv.gs+=gm;
      if(gv>gm){tv.v++;tv.ult5.push('v');}
      else if(gv===gm){tv.e++;tv.ult5.push('e');}
      else{tv.d++;tv.ult5.push('d');}
      console.log(`  ✅ Visitante ${tv.nome}: J=${tv.j} V=${tv.v} E=${tv.e} D=${tv.d} GM=${tv.gm} GS=${tv.gs}`);
    }
  });

  // 5. Calcula pontos (V=3pts, E=1pt, D=0pts + gols marcados +1, gols sofridos -1) e saldo
  dados.times.forEach(t=>{
    // Pontuação FIFA: 3pts vitória, 1pt empate + bônus de gols (marcados +1, sofridos -1)
    t.pts = (t.v*3 + t.e*1) + (t.gm*1) - (t.gs*1);
    t.sg = t.gm - t.gs;
    
    // Mantém apenas últimos 5 resultados
    if(t.ult5.length > 5){
      t.ult5 = t.ult5.slice(-5);
    }
    // Preenche com vazios se tiver menos de 5
    while(t.ult5.length < 5){
      t.ult5.unshift('');
    }
    
    console.log(`📈 ${t.nome}: PTS=${t.pts} SG=${t.sg} ULT5=[${t.ult5.join(',')}]`);
  });
  
  console.log('✅ Classificação recalculada com sucesso!');
}

/* ================================================================
   CLASSIFICAÇÃO — cálculo FIFA
================================================================ */
function calcTime(t){
  t.pts   = (t.v*3 + t.e*1) + (t.gm*1) - (t.gs*1);
  t.sg    = t.gm - t.gs;
}

function renderClassificacao(){
  console.log('🎨 Renderizando tabela de classificação...');
  
  // 1. Ordena times por critérios FIFA
  dados.times.sort((a,b)=>{
    if(b.pts!==a.pts) return b.pts-a.pts;
    if(b.sg !==a.sg)  return b.sg -a.sg;
    if(b.gm !==a.gm)  return b.gm -a.gm;
    return b.v-a.v;
  });

  // 2. Limpa tabela
  const tbody=document.getElementById('bodyClassificacao');
  if(!tbody){
    console.error('❌ Elemento bodyClassificacao não encontrado!');
    return;
  }
  tbody.innerHTML='';
  
  const total=dados.times.length;
  console.log(`📋 Renderizando ${total} times`);

  // 3. Renderiza cada time
  dados.times.forEach((t,i)=>{
    const pos=i+1;
    let zone='zone-mid';
    if(total>=4 && pos<=4)       zone='zone-class';
    if(total>=4 && pos>total-2)  zone='zone-rel';

    let posDisplay;
    if(pos===1) posDisplay=`<span class="pos-medal-1">🥇 1º</span>`;
    else if(pos===2) posDisplay=`<span class="pos-medal-2">🥈 2º</span>`;
