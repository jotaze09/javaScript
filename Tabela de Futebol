function aplicarTema(id){
  temaAtual = id;

  // Remover todas as classes de tema do body
  document.body.classList.remove('light-theme', 'roxo-elegante-theme', 'pumpkin-theme');
  
  // Adicionar classe específica para temas que precisam de ajustes
  if (id === 'light') {
    document.body.classList.add('light-theme');
  } else if (id === 'roxo-elegante') {
    document.body.classList.add('roxo-elegante-theme');
  } else if (id === 'pumpkin') {
    document.body.classList.add('pumpkin-theme');
  }

  const vars = TEMA_VARS[id] || TEMA_VARS['default'];

  Object.entries(vars).forEach(([k,v]) => {
    document.documentElement.style.setProperty(k, v);
  });

  // 🔥 FORÇA repaint (hack importante)
  document.body.style.display = 'none';
  document.body.offsetHeight; 
  document.body.style.display = '';

  localStorage.setItem('temaAtual', id);

  renderTemas();
}





