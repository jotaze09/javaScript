    else posDisplay=`<strong>${pos}º</strong>`;

    const dots=(t.ult5||[]).map(r=>r?`<span class="dot ${r}">${r.toUpperCase()}</span>`:'').join('');
    const sgColor=t.sg>0?'var(--green)':t.sg<0?'var(--red)':'var(--text)';
    const sgTxt=(t.sg>0?'+':'')+t.sg;

    const tr=document.createElement('tr');
    tr.className=zone;
    tr.style.animationDelay=(i*0.04)+'s';
    tr.innerHTML=`
      <td>${posDisplay}</td>
      <td>
        <div style="display:flex;align-items:center;gap:4px;">
          <input type="file" id="foto-classif-${t.id}" accept="image/*" style="display:none;" onchange="carregarFotoTime(${t.id}, this)">
