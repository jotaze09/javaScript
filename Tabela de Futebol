function updPart(id,campo,val){
  const p=dados.partidas.find(x=>x.id===id);
  if(!p) return;
  
  const valorAnterior = p[campo];
  p[campo]=(typeof val==='string')?val.trim():val;
  console.log(`📝 Atualizando partida ${id}: ${campo} ${valorAnterior} → ${p[campo]}`);
  
  if(campo === 'mandante' || campo === 'visitante'){
    console.log('🔄 Nomes dos times alterados, atualizando interface...');
    atualizarNomesTimesDinamicamente(p.id, campo, p[campo]);
    recalcularClassificacaoPorPartidas();
    renderClassificacao();
    renderTimes(); // Atualiza aba Times quando nomes mudam
  }
  
  atualizarDashboard();
  renderTimes(); // Atualização automática da aba Times
  salvarLocal();
}

function atualizarNomesTimesDinamicamente(partidaId, campo, novoNome){
  const container = document.querySelector(`.match-card[data-partida="${partidaId}"]`);
  if(!container) return;
  
  console.log(`🎯 Atualizando nome do time dinamicamente: ${campo} - ${novoNome}`);
  
  const timeClass = campo === 'mandante' ? '.time-name-mandante' : '.time-name-visitante';
  const elementosNome = container.querySelectorAll(timeClass);
  elementosNome.forEach(el => el.textContent = novoNome);
  
  const campoPrincipal = container.querySelector(`span[onblur*="'${campo}'"]`);
  if(campoPrincipal && campoPrincipal.textContent !== novoNome){
    campoPrincipal.textContent = novoNome;
  }
}

function updPartN(id,campo,val){
  const p=dados.partidas.find(x=>x.id===id);
