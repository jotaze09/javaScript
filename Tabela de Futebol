<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tabela de Futebol Escolar</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;800&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}

    :root{
      --bg:#000000;--neon-dark:#7b00cc;--accent:#e040fb;--text:#f0e6ff;
      --text-sec:#a855f7;--zebra:#1a0030;--green:#00ff88;--red:#ff003c;
      --yellow:#ffd600;--blue:#00bfff;--bg-card:#0a0010;--neon:#bf00ff;
      --th-bg:linear-gradient(135deg,#7b00cc,#1a0030);
      --header-bg:rgba(10,0,16,.88);
      --font-scale:1;
    }

    /* Tamanhos de fonte */
    body{font-size:calc(16px * var(--font-scale))}
    .nav-tab{font-size:calc(.65rem * var(--font-scale))}
    .match-team .name{font-size:calc(0.9rem * var(--font-scale))}
    .match-team .emoji{font-size:calc(9rem * var(--font-scale))}
    .detail-row{font-size:calc(.73rem * var(--font-scale))}
    .match-toggle{font-size:calc(.62rem * var(--font-scale))}
    .badge, select{font-size:calc(.63rem * var(--font-scale))}
    .btn-del span{font-size:calc(.6rem * var(--font-scale))}
    .pts-cell{font-size:calc(.95rem * var(--font-scale))}
    .theme-name{font-size:calc(1.1rem * var(--font-scale))}
    .theme-desc{font-size:calc(.75rem * var(--font-scale))}
    .theme-btn{font-size:calc(.8rem * var(--font-scale))}
    .dash-card .label{font-size:calc(.7rem * var(--font-scale))}
    .dash-card .value{font-size:calc(1.4rem * var(--font-scale))}
    th,td{font-size:calc(.75rem * var(--font-scale))}
    .pos-medal-1{font-size:calc(1rem * var(--font-scale))}
    .section-title{font-size:calc(1.1rem * var(--font-scale))}
    .match-meta, .match-header input{font-size:calc(.68rem * var(--font-scale))}
    .info-box, .info-box strong{font-size:calc(.75rem * var(--font-scale))}
    .detail-group h4{font-size:calc(.58rem * var(--font-scale))}
    .dev-credit{font-size:.6rem !important}

    body{
      font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);
      min-height:100vh;overflow-x:hidden;scroll-behavior:smooth;
      transition:background .4s,color .4s,border-color .4s;
    }
    ::-webkit-scrollbar{width:8px;height:8px}
    ::-webkit-scrollbar-track{background:var(--bg)}
    ::-webkit-scrollbar-thumb{background:var(--neon);border-radius:4px}
    ::-webkit-scrollbar-thumb:hover{background:var(--accent)}

    .header{
      position:fixed;top:0;left:0;right:0;z-index:1000;
      background:var(--header-bg);backdrop-filter:blur(16px);
      border-bottom:1px solid var(--neon);box-shadow:0 0 20px rgba(0,0,0,.3);
      padding:calc(10px * var(--font-scale)) calc(20px * var(--font-scale));display:flex;align-items:center;
      justify-content:space-between;flex-wrap:wrap;gap:calc(8px * var(--font-scale));
      transition:background .4s,border-color .4s,box-shadow .4s;
    }
    .logo-area{display:flex;align-items:center;gap:10px}
    .logo-icon{font-size:calc(.65rem * var(--font-scale));color:var(--text-sec);letter-spacing:1px}
    .logo-title{
      font-family:'Orbitron',sans-serif;font-size:calc(1.1rem * var(--font-scale));font-weight:800;
      color:var(--neon);text-shadow:0 0 10px var(--neon),0 0 20px var(--neon-dark);cursor:pointer;
      transition:color .4s,text-shadow .4s;
    }
    @keyframes glowPulse{
      0%,100%{text-shadow:0 0 10px var(--neon),0 0 20px var(--neon),0 0 40px var(--neon-dark)}
      50%{text-shadow:0 0 20px var(--accent),0 0 40px var(--neon),0 0 60px var(--neon-dark)}
    }
    .nav-tabs{display:flex;gap:calc(8px * var(--font-scale));flex-wrap:wrap}
    .nav-tab{
      font-family:'Orbitron',sans-serif;font-size:calc(.65rem * var(--font-scale));padding:calc(7px * var(--font-scale)) calc(14px * var(--font-scale));
      border:1px solid var(--neon-dark);background:transparent;color:var(--text-sec);
      cursor:pointer;border-radius:6px;transition:all .3s;white-space:nowrap;
    }
    .nav-tab:hover{
      background:rgba(191,0,255,.2);color:var(--accent);border-color:var(--accent);
    }
    .nav-tab.active{
      background:var(--accent);color:#fff;box-shadow:0 0 14px var(--accent);
      border-color:var(--accent);animation:glowPulse .8s ease-in-out alternate infinite;
    }
    .hamburger{display:none;font-size:calc(1.4rem * var(--font-scale));color:var(--neon);cursor:pointer;background:none;border:none}
    .main{margin-top:calc(70px * var(--font-scale));max-width:1400px;margin-left:auto;margin-right:auto;padding:0 calc(16px * var(--font-scale)) calc(48px * var(--font-scale));position:relative}
    .section{display:none;animation:fadeInSection .45s ease}
    .section.active{display:block}
    @keyframes fadeInSection{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

    .dashboard{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;margin-bottom:28px}
    .dash-card{
      background:var(--bg-card);border:1px solid var(--neon-dark);border-radius:12px;
      padding:15px;text-align:center;box-shadow:0 0 10px rgba(191,0,255,.12);
      transition:all .3s;position:relative;overflow:hidden;
    }
    .dash-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--neon),transparent)}
    .dash-card:hover{transform:translateY(-3px);box-shadow:0 0 22px rgba(191,0,255,.38);border-color:var(--neon)}
    .dash-card .icon{font-size:1.4rem;margin-bottom:5px}
    .dash-card .label{font-size:.6rem;color:var(--text-sec);text-transform:uppercase;letter-spacing:1px;font-family:'Orbitron',sans-serif}
    .dash-card .value{font-size:1.3rem;font-weight:700;color:var(--accent);margin-top:4px;font-family:'Orbitron',sans-serif}

    .section-title{
      font-family:'Orbitron',sans-serif;font-size:1rem;color:var(--neon);
      text-shadow:0 0 10px var(--neon-dark);margin:28px 0 14px;padding-bottom:8px;
      border-bottom:2px solid transparent;border-image:linear-gradient(90deg,var(--neon),transparent) 1;
      display:flex;align-items:center;gap:10px;
    }
    .section-title i{color:var(--accent)}

    .table-wrapper{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid var(--neon);
      border-radius:12px;
      box-shadow:0 0 18px rgba(191,0,255,.18);
      margin-bottom:22px;
      background:var(--bg-card);
      width:100%;
      max-width:100%;
      position:relative;
      -webkit-overflow-scrolling:touch;
    }
    table{
      width:100%;
      min-width:1200px;
      border-collapse:collapse;
      font-size:.8rem;
    }
    thead{background:var(--th-bg);position:sticky;top:0;z-index:5}
    th{padding:11px 9px;text-align:center;font-family:'Orbitron',sans-serif;font-size:.58rem;color:var(--accent);text-transform:uppercase;letter-spacing:1px;white-space:nowrap;border-bottom:2px solid var(--neon)}
    td{padding:9px 7px;text-align:center;border-bottom:1px solid rgba(191,0,255,.13);white-space:nowrap;transition:background .25s}
    tr:nth-child(even) td{background:var(--zebra)}
    tr:nth-child(odd) td{background:var(--bg-card)}
    tbody tr{animation:fadeInRow .38s ease both}
    tbody tr:hover td{background:rgba(191,0,255,.14)!important}
    @keyframes fadeInRow{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
    td[contenteditable]:focus{outline:2px solid var(--accent);border-radius:3px;background:rgba(224,64,251,.08)!important}
    select{background:var(--bg-card);color:var(--text);border:1px solid var(--neon-dark);border-radius:4px;padding:3px 6px;font-size:calc(.72rem * var(--font-scale));cursor:pointer}
    select:focus{outline:1px solid var(--accent);box-shadow:0 0 7px var(--neon)}

    .zone-class td:first-child{border-left:3px solid var(--green);box-shadow:inset 4px 0 8px rgba(0,255,136,.12)}
    .zone-mid td:first-child{border-left:3px solid var(--yellow);box-shadow:inset 4px 0 8px rgba(255,214,0,.12)}
    .zone-rel td:first-child{border-left:3px solid var(--red);box-shadow:inset 4px 0 8px rgba(255,0,60,.12)}

    .result-dots{display:flex;gap:3px;justify-content:center}
    .dot{width:15px;height:15px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:.48rem;font-weight:700;color:#000}
    .dot.v{background:#00ff88 !important;box-shadow:0 0 5px #00ff88 !important}
    .dot.e{background:var(--yellow);box-shadow:0 0 5px var(--yellow)}
    .dot.d{background:#ff003c !important;box-shadow:0 0 5px #ff003c !important}

    .legenda{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:10px;font-size:.7rem}
    .legenda-item{display:flex;align-items:center;gap:6px}
    .legenda-cor{width:12px;height:12px;border-radius:2px}

    .btn-add{
      display:inline-flex;align-items:center;gap:6px;padding:9px 18px;
      border:1px dashed var(--neon);background:rgba(191,0,255,.05);color:var(--accent);
      font-family:'Orbitron',sans-serif;font-size:.68rem;cursor:pointer;
      border-radius:8px;transition:all .3s;margin-top:8px;
    }
    .btn-add:hover{background:rgba(191,0,255,.18);box-shadow:0 0 14px var(--neon)}
    .btn-del{background:none;border:none;color:var(--red);cursor:pointer;font-size:calc(.95rem * var(--font-scale));transition:all .3s;opacity:.55}
    .btn-del:hover{opacity:1;text-shadow:0 0 9px var(--red);transform:scale(1.2)}

    .badge{padding:3px 8px;border-radius:10px;font-size:calc(.58rem * var(--font-scale));font-weight:700;text-transform:uppercase;letter-spacing:.5px;display:inline-block}
    .badge-agendado{background:rgba(0,191,255,.12);color:var(--blue);border:1px solid var(--blue);box-shadow:0 0 5px rgba(0,191,255,.25)}
    .badge-aovivo{background:rgba(255,0,60,.18);color:#ff003c;border:1px solid #ff003c;box-shadow:0 0 5px rgba(255,0,60,.35);animation:pulseLive 1s infinite}
    .badge-encerrado{background:rgba(0,255,136,.12);color:var(--green);border:1px solid var(--green);box-shadow:0 0 5px rgba(0,255,136,.25)}
    .badge-cancelado{background:rgba(128,128,128,.12);color:#888;border:1px solid #555}
    .badge-adiado{background:rgba(255,214,0,.12);color:var(--yellow);border:1px solid var(--yellow);box-shadow:0 0 5px rgba(255,214,0,.25)}
    @keyframes pulseLive{0%,100%{box-shadow:0 0 5px rgba(255,0,60,.35)}50%{box-shadow:0 0 18px rgba(255,0,60,.85)}}

    .match-card{
      background:var(--bg-card);border:1px solid var(--neon-dark);border-radius:14px;
      padding:18px;margin-bottom:18px;box-shadow:0 0 10px rgba(191,0,255,.12);
      transition:box-shadow .3s,border-color .3s,transform .3s;
    }
    .match-card:hover{box-shadow:0 0 22px rgba(191,0,255,.3);transform:translateY(-2px)}
    .match-card-enter{animation:fadeInCard .45s ease both}
    @keyframes fadeInCard{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
    .match-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid rgba(191,0,255,.18)}
    .match-meta{font-size:calc(.68rem * var(--font-scale));color:var(--text-sec)}
    .match-scoreboard{display:flex;align-items:center;justify-content:center;gap:14px;margin:12px 0}
    .match-team{text-align:center;flex:1;min-width:90px}
    .match-team .emoji{font-size:calc(9rem * var(--font-scale));display:block;margin-bottom:8px}
    .match-team .name{font-family:'Orbitron',sans-serif;font-size:calc(0.9rem * var(--font-scale));color:var(--text)}
    .match-score{font-family:'Orbitron',sans-serif;font-size:2.8rem;color:var(--accent);text-shadow:0 0 14px var(--neon);display:flex;align-items:center;gap:14px}
    .match-score .x{font-size:1.2rem;color:var(--text-sec)}
    .gols-toggle-btn{position:absolute;top:-8px;right:-8px;background:var(--accent);color:#fff;border:none;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:.7rem;cursor:pointer;box-shadow:0 0 10px var(--accent);z-index:10;transition:all .3s}
    .gols-toggle-btn:hover{transform:scale(1.1);box-shadow:0 0 15px var(--accent)}
    .match-team{position:relative;text-align:center;flex:1;min-width:90px}
    .gols-container{display:none;margin-top:4px;animation:fadeInGols .3s ease}
    .gols-container.show{display:block}
    @keyframes fadeInGols{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}
    .match-details{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px}
    .detail-group{background:rgba(191,0,255,.04);border:1px solid rgba(191,0,255,.1);border-radius:8px;padding:11px}
    .detail-group h4{font-family:'Orbitron',sans-serif;font-size:calc(.58rem * var(--font-scale));color:var(--accent);margin-bottom:7px;text-transform:uppercase;letter-spacing:1px}
    .detail-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-size:calc(.73rem * var(--font-scale));border-bottom:1px solid rgba(191,0,255,.05)}
    .detail-row:last-child{border:none}
    .detail-row .lbl{color:var(--text-sec)}
    .detail-row .val{color:var(--text);font-weight:600}
    .match-toggle{background:none;border:1px solid var(--neon-dark);color:var(--text-sec);font-size:calc(.62rem * var(--font-scale));padding:4px 10px;border-radius:4px;cursor:pointer;transition:all .3s;font-family:'Orbitron',sans-serif}
    .match-toggle:hover{background:var(--neon);color:#fff;box-shadow:0 0 9px var(--neon)}
    .match-expandable{max-height:0;overflow:hidden;transition:max-height .4s ease}
    .match-expandable.show{max-height:2000px}
    
    /* Botões de Formatação */
    .format-btn{
      background:none;border:none;color:var(--text-sec);font-size:.8rem;padding:6px 10px;cursor:pointer;transition:all .3s;display:flex;align-items:center;justify-content:center;min-width:36px;
    }
    .format-btn:hover{
      background:rgba(191,0,255,.15);
      color:var(--accent);
      border:1px solid rgba(191,0,255,.3);
    }
    .format-btn.active{
      background:var(--neon);
      color:#fff;
      box-shadow:0 0 8px var(--neon);
      border:1px solid var(--neon);
    }
    
    /* Ajustes específicos para tema claro */
    body.light-theme .format-btn:hover{
      background:rgba(124,58,237,.15);
      color:var(--accent);
      border:1px solid rgba(124,58,237,.3);
    }
    body.light-theme .format-btn.active{
      background:var(--accent);
      color:#fff;
      box-shadow:0 0 8px var(--accent);
      border:1px solid var(--accent);
    }
    
    /* Ajustes para tema roxo-elegante */
    body.roxo-elegante-theme .format-btn:hover{
      background:rgba(168,85,247,.15);
      color:var(--accent);
      border:1px solid rgba(168,85,247,.3);
    }
    body.roxo-elegante-theme .format-btn.active{
      background:var(--accent);
      color:#fff;
      box-shadow:0 0 8px var(--accent);
      border:1px solid var(--accent);
    }
    
    
    /* Ajustes para tema pumpkin */
    body.pumpkin-theme .format-btn:hover{
      background:rgba(255,140,0,.15);
      color:var(--accent);
      border:1px solid rgba(255,140,0,.3);
    }
    body.pumpkin-theme .format-btn.active{
      background:var(--accent);
      color:#fff;
      box-shadow:0 0 8px var(--accent);
      border:1px solid var(--accent);
    }
    
    /* Apenas títulos das abas com texto branco no high contrast - cinza ainda mais claro */
    body.highcontrast-theme .nav-tab.active,
    body.highcontrast-theme button.nav-tab.active,
    body.highcontrast-theme .nav-tabs button.active,
    body.highcontrast-theme .nav-tab[data-tab].active{
      color:#FFFFFF !important; 
      background:#777777 !important;
      border:1px solid #777777 !important;
    }
    
    /* Forçando todos os elementos internos dos botões */
    body.highcontrast-theme .nav-tab.active *,
    body.highcontrast-theme button.nav-tab.active *{
      color:#FFFFFF !important;
    }
    
    /* Ajustes específicos para textos das partidas em temas problemáticos */
    body.softmono-theme .match-team .name{
      color:#555555; /* Texto cinza para melhor contraste */
    }
    body.softmono-theme .match-score{
      color:#555555; /* Texto cinza para melhor contraste */
    }
    body.softmono-theme .detail-group h4{
      color:#000; /* Texto preto para melhor contraste */
    }
    body.softmono-theme .detail-row .val{
      color:#000; /* Texto preto para melhor contraste */
    }
    
    /* Soft Mono - mesma correção do high contrast */
    body.softmono-theme .match-team .name{
      color:#555555; /* Texto cinza para contraste com fundo branco */
    }
    body.softmono-theme .match-score{
      color:#555555; /* Texto cinza para contraste */
    }
    body.softmono-theme .match-score .x{
      color:#555555; /* Texto cinza para contraste */
    }
    body.softmono-theme .detail-group h4{
      color:#000000; /* Texto preto para títulos */
    }
    body.softmono-theme .detail-row .lbl{
      color:#555555; /* Texto cinza para rótulos */
    }
    body.softmono-theme .detail-row .val{
      color:#000000; /* Texto preto para valores */
    }
    body.softmono-theme .match-meta{
      color:#555555; /* Texto cinza para metadados */
    }
    body.softmono-theme .match-header{
      border-bottom-color: #E5E7EB; /* Borda mais clara */
    }
    
    /* Botões superiores com texto branco apenas no soft mono - REFORÇADO */
    body.softmono-theme .btn-add,
    body.softmono-theme .btn-add *,
    body.softmono-theme button.btn-add{
      color:#fff !important;
      background:#000000 !important;
      border-color:#000000 !important;
    }
    body.softmono-theme .btn-del,
    body.softmono-theme .btn-del *,
    body.softmono-theme button.btn-del{
      color:#fff !important;
      background:#dc2626 !important;
      border-color:#dc2626 !important;
    }
    body.softmono-theme .match-toggle,
    body.softmono-theme .match-toggle *,
    body.softmono-theme button.match-toggle{
      color:#fff !important;
      background:#000000 !important;
      border-color:#000000 !important;
    }
    
    /* Forçando texto branco em todos os elementos internos dos botões */
    body.softmono-theme .btn-add i,
    body.softmono-theme .btn-add span,
    body.softmono-theme .btn-del i,
    body.softmono-theme .btn-del span,
    body.softmono-theme .match-toggle i,
    body.softmono-theme .match-toggle span{
      color:#fff !important;
    }
    
    body.pumpkin-theme .match-team .name{
      color:#fff; /* Texto branco garantido */
    }
    body.pumpkin-theme .match-meta{
      color:#fff; /* Texto branco garantido */
    }
    body.pumpkin-theme .match-score .x{
      color:#fff; /* Texto branco garantido */
    }
    body.pumpkin-theme .detail-row .lbl{
      color:#ff9a4d; /* Cor secundária do tema */
    }
    body.pumpkin-theme .detail-row .val{
      color:#fff; /* Texto branco garantido */
    }
    
    /* Layout Grade (Grid) */
    .partidas-grid{
      display:grid;grid-template-columns:repeat(2,1fr);gap:16px;max-width:1200px;margin:0 auto;
    }
    .partidas-grid .match-card{
      margin-bottom:0;
    }
    
    /* Layout Linha (List) */
    .partidas-list{
      display:flex;flex-direction:column;gap:8px;
    }
    .partidas-list .match-card{
      margin-bottom:0;padding:12px 16px;
    }
    .partidas-list .match-header{
      margin-bottom:8px;padding-bottom:6px;
    }
    .partidas-list .match-scoreboard{
      margin:8px 0;gap:10px;
    }
    .partidas-list .match-score{
      font-size:1.4rem !important;
    }
    .partidas-list .match-team .emoji{
      font-size:5.6rem;
    }
    .partidas-list .match-team .name{
      font-size:0.8rem;
    }
    .partidas-list .gols-toggle-btn{
      top:-4px;right:-4px;width:20px;height:20px;font-size:.65rem;
    }
    /* No formato LINHA, reorganizar detalhes */
    .partidas-list .match-expandable.show{max-height:3000px}
    .partidas-list .match-details{
      grid-template-columns:1fr 1fr;gap:10px;margin-top:8px;
    }
    /* Informações da partida em largura total */
    .partidas-list .match-details:first-of-type{
      grid-template-columns:1fr;
    }
    .partidas-list .match-details:first-of-type .detail-group{
      max-width:600px;margin:0 auto;
    }
    .partidas-list .detail-group{
      padding:8px;
    }
    .partidas-list .detail-group h4{
      font-size:calc(.52rem * var(--font-scale));margin-bottom:5px;
    }
    .partidas-list .detail-row{
      font-size:calc(.65rem * var(--font-scale));padding:2px 0;
    }
    
    /* Responsivo */
    @media (max-width:768px){
      .partidas-grid{
        grid-template-columns:1fr;
      }
      @media (max-width:1024px){
        .partidas-grid{
          grid-template-columns:repeat(2,1fr);
        }
