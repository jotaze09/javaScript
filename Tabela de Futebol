function renderPartidas(){
  const container=document.getElementById('listaPartidas');
  container.innerHTML='';
  
  // Aplicar formato selecionado
  container.classList.remove('partidas-grid', 'partidas-list');
  container.classList.add(`partidas-${partidaFormat}`);
  
  dados.partidas.forEach((p,idx)=>{
    const card=document.createElement('div');
    card.className=`match-card ${statusCardClass(p.status)} match-card-enter`;
    card.style.animationDelay=(idx*0.07)+'s';
    card.dataset.partida=p.id;
    card.innerHTML=cardInnerHTML(p);
    
    // Clique no card expande/recolhe detalhes (exceto em elementos interativos)
    card.addEventListener('click', function(e){
      const target = e.target;
      const isInteractive = target.closest('button') || target.closest('select') || target.closest('input') || target.closest('[contenteditable]') || target.closest('.match-expandable');
      if (!isInteractive) {
        const toggleBtn = this.querySelector('.match-toggle');
        if (toggleBtn) toggleMatch(toggleBtn);
      }
    });
    
    container.appendChild(card);
  });
  
  atualizarDashboard();
}

function toggleMatch(btn){
  const exp=btn.parentElement.nextElementSibling;
  exp.classList.toggle('show');
  btn.innerHTML=exp.classList.contains('show')
    ?'<i class="fa-solid fa-eye-slash"></i> Ocultar Detalhes'
    :'<i class="fa-solid fa-chart-bar"></i> Ver Detalhes';
}

