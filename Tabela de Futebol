function atualizarCamposGolsDinamicamente(partidaId, campoPlacar, novoNumGols){
  const time = campoPlacar === 'golsMandante' ? 'mandante' : 'visitante';
  const container = document.getElementById(`gols-${time}-${partidaId}`);
  
  if(!container) return;
  
  console.log(`🎯 Atualizando campos de gols dinamicamente: ${time} - ${novoNumGols} gols`);
  
  const campoMarcadores = time === 'mandante' ? 'golsMandanteMarcadores' : 'golsVisitanteMarcadores';
  const marcadores = dados.partidas.find(p=>p.id===partidaId)[campoMarcadores] || [];
  
  container.innerHTML = renderCamposGols(partidaId, time, novoNumGols, marcadores);
}

function renderCamposGols(partidaId, time, numGols, marcadores){
  let campos = '';
  const textAlign = time === 'mandante' ? 'right' : 'left';
  
  for(let i = 0; i < numGols; i++){
    const valor = marcadores && marcadores[i] ? marcadores[i] : '';
    campos += `
      <div style="margin:2px 0">
        <input type="text" 
          value="${valor}" 
          placeholder="jogador;minuto" 
          onchange="updMarcadorIndividual(${partidaId}, '${time}', ${i}, this.value)"
          style="width:100%;background:transparent;border:none;border-bottom:1px solid var(--neon-dark);padding:2px 4px;font-size:calc(.55rem * var(--font-scale));color:var(--text);text-align:${textAlign}">
      </div>
    `;
  }
  
  return campos;
}

function updMarcadorIndividual(partidaId, time, golIndex, valor){
  const p=dados.partidas.find(x=>x.id===partidaId);
  if(!p) return;
  
  const campo = time === 'mandante' ? 'golsMandanteMarcadores' : 'golsVisitanteMarcadores';
  
  if(!p[campo]) p[campo] = [];
  p[campo][golIndex] = valor.trim();
  
  console.log(`⚽ Atualizando gol ${golIndex+1} ${time} partida ${partidaId}: ${valor.trim()}`);
  salvarLocal();
