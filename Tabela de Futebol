let ajusteFotoAtual = { timeId: null, imagemOriginal: null, zoom: 1, posX: 0, posY: 0 };
let isDragging = false;
let dragStartX = 0;
let dragStartY = 0;

function carregarFotoTime(timeId, input) {
  const file = input.files[0];
  if (!file) return;
  
  // Verifica se é uma imagem
  if (!file.type.startsWith('image/')) {
    alert('Por favor, selecione um arquivo de imagem válido.');
    return;
  }
  
  // Verifica tamanho máximo (5MB)
  if (file.size > 5 * 1024 * 1024) {
    alert('A imagem deve ter no máximo 5MB.');
    return;
  }
  
  const reader = new FileReader();
  reader.onload = function(e) {
    // Abre modal de ajuste
    abrirModalAjusteFoto(timeId, e.target.result);
  };
  reader.readAsDataURL(file);
}

function abrirModalAjusteFoto(timeId, imagemData) {
  ajusteFotoAtual = {
    timeId: timeId,
    imagemOriginal: imagemData,
    zoom: 1,
    posX: 0,
    posY: 0
  };
  
  const ajusteImagem = document.getElementById('ajusteImagem');
  const previewImagem = document.getElementById('previewImagem');
  const zoomSlider = document.getElementById('zoomSlider');
  const zoomValue = document.getElementById('zoomValue');
  
  ajusteImagem.src = imagemData;
  previewImagem.src = imagemData;
  zoomSlider.value = 1;
  zoomValue.textContent = '1.0x';
  
  resetarPosicao();
  atualizarPreview();
  
  document.getElementById('modalAjusteFoto').classList.add('show');
}

function resetarPosicao() {
  ajusteFotoAtual.posX = 0;
  ajusteFotoAtual.posY = 0;
  ajusteFotoAtual.zoom = 1;
  
  const ajusteImagem = document.getElementById('ajusteImagem');
  ajusteImagem.style.transform = 'translate(-50%, -50%) scale(1)';
  ajusteImagem.style.left = '50%';
  ajusteImagem.style.top = '50%';
}

function resetarAjuste() {
  resetarPosicao();
  document.getElementById('zoomSlider').value = 1;
  document.getElementById('zoomValue').textContent = '1.0x';
  atualizarPreview();
}

function atualizarPreview() {
  const ajusteImagem = document.getElementById('ajusteImagem');
  const previewImagem = document.getElementById('previewImagem');
  
  // Aplica transformação na imagem de ajuste
  ajusteImagem.style.transform = `translate(calc(-50% + ${ajusteFotoAtual.posX}px), calc(-50% + ${ajusteFotoAtual.posY}px)) scale(${ajusteFotoAtual.zoom})`;
  
  // Cria canvas para gerar preview
  const canvas = document.createElement('canvas');
  canvas.width = 80;
  canvas.height = 80;
  const ctx = canvas.getContext('2d');
  
  const img = new Image();
  img.onload = function() {
    // Calcula proporção para manter aspect ratio
    const imgRatio = img.width / img.height;
    const canvasRatio = 1; // 80/80 = 1
    
    let drawWidth, drawHeight;
    if (imgRatio > canvasRatio) {
      drawWidth = 80 * imgRatio;
      drawHeight = 80;
    } else {
      drawWidth = 80;
      drawHeight = 80 / imgRatio;
    }
    
    ctx.save();
    ctx.beginPath();
    ctx.arc(40, 40, 40, 0, Math.PI * 2);
    ctx.clip();
    
    const scale = ajusteFotoAtual.zoom;
    const offsetX = ajusteFotoAtual.posX;
    const offsetY = ajusteFotoAtual.posY;
    
    ctx.translate(40 + offsetX, 40 + offsetY);
    ctx.scale(scale, scale);
    ctx.drawImage(img, -drawWidth/2, -drawHeight/2, drawWidth, drawHeight);
    ctx.restore();
    
    previewImagem.src = canvas.toDataURL();
  };
  img.src = ajusteFotoAtual.imagemOriginal;
}

function confirmarAjusteFoto() {
  const canvas = document.createElement('canvas');
  canvas.width = 200;
  canvas.height = 200;
  const ctx = canvas.getContext('2d');
  
  const img = new Image();
  img.onload = function() {
    // Calcula proporção para manter aspect ratio
    const imgRatio = img.width / img.height;
    const canvasRatio = 1; // 200/200 = 1
    
    let drawWidth, drawHeight;
    if (imgRatio > canvasRatio) {
      drawWidth = 200 * imgRatio;
      drawHeight = 200;
    } else {
      drawWidth = 200;
      drawHeight = 200 / imgRatio;
    }
    
    ctx.save();
    ctx.beginPath();
    ctx.arc(100, 100, 100, 0, Math.PI * 2);
    ctx.clip();
    
    const scale = ajusteFotoAtual.zoom;
    const offsetX = ajusteFotoAtual.posX * (200/80); // Ajusta proporção
    const offsetY = ajusteFotoAtual.posY * (200/80);
    
    ctx.translate(100 + offsetX, 100 + offsetY);
    ctx.scale(scale, scale);
    ctx.drawImage(img, -drawWidth/2, -drawHeight/2, drawWidth, drawHeight);
    ctx.restore();
    
    const imagemFinal = canvas.toDataURL('image/png', 0.9);
    
    const time = dados.times.find(t => t.id === ajusteFotoAtual.timeId);
    if (time) {
      time.foto = imagemFinal;
      console.log(`📸 Foto ajustada e salva para o time: ${time.nome}`);
      salvarLocal();
      renderTimes();
      renderClassificacao();
      renderPartidas();
    }
    
    cancelarAjusteFoto();
  };
  img.src = ajusteFotoAtual.imagemOriginal;
}

function cancelarAjusteFoto() {
  document.getElementById('modalAjusteFoto').classList.remove('show');
  ajusteFotoAtual = { timeId: null, imagemOriginal: null, zoom: 1, posX: 0, posY: 0 };
}

// Event listeners para drag e zoom
document.addEventListener('DOMContentLoaded', function() {
  const ajusteContainer = document.getElementById('ajusteContainer');
  const zoomSlider = document.getElementById('zoomSlider');
  const zoomValue = document.getElementById('zoomValue');
  
  // Drag functionality
  ajusteContainer.addEventListener('mousedown', function(e) {
    isDragging = true;
    dragStartX = e.clientX - ajusteFotoAtual.posX;
    dragStartY = e.clientY - ajusteFotoAtual.posY;
    ajusteContainer.style.cursor = 'grabbing';
  });
  
  document.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    
    ajusteFotoAtual.posX = e.clientX - dragStartX;
    ajusteFotoAtual.posY = e.clientY - dragStartY;
    
    atualizarPreview();
  });
  
  document.addEventListener('mouseup', function() {
    isDragging = false;
    ajusteContainer.style.cursor = 'move';
  });
  
  // Zoom slider
  zoomSlider.addEventListener('input', function(e) {
    ajusteFotoAtual.zoom = parseFloat(e.target.value);
    zoomValue.textContent = ajusteFotoAtual.zoom.toFixed(1) + 'x';
    atualizarPreview();
  });
});

