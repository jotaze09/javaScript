// FUNÇÃO UNIVERSAL PARA CONTAR CARTÕES - REFEITA DO ZERO
function contarCartoesSimples(disciplina, tipo) {
  console.log(`🔍 [DEBUG] contarCartoesSimples chamado com:`, { disciplina, tipo });
  
  // Verificação básica
  if (!disciplina) {
    console.log(`� [DEBUG] disciplina é null/undefined`);
    return 0;
  }
  
  if (!disciplina[tipo]) {
    console.log(`🔍 [DEBUG] disciplina[${tipo}] é null/undefined`);
    return 0;
  }
  
  const cartoes = disciplina[tipo];
  console.log(`🔍 [DEBUG] cartões =`, cartoes, `tipo =`, typeof cartoes);
  
  // CASO 1: Array (o mais comum)
  if (Array.isArray(cartoes)) {
    const resultado = cartoes.length;
    console.log(`🔍 [DEBUG] É array! Length = ${resultado}`);
    return resultado;
  }
  
  // CASO 2: String formatada como "jogador1;jogador2"
  if (typeof cartoes === 'string') {
    if (cartoes.trim() === '' || cartoes.trim() === 'Nenhum') {
      console.log(`🔍 [DEBUG] String vazia ou "Nenhum"`);
      return 0;
    }
    const partes = cartoes.split(';').filter(s => s.trim());
    const resultado = partes.length;
    console.log(`🔍 [DEBUG] String "${cartoes}" dividida em ${resultado} partes`);
    return resultado;
  }
  
  // CASO 3: Número direto
  if (typeof cartoes === 'number') {
    console.log(`🔍 [DEBUG] É número direto: ${cartoes}`);
    return cartoes;
  }
  
  // CASO 4: Objeto com chaves numéricas
  if (typeof cartoes === 'object' && cartoes !== null) {
    const chaves = Object.keys(cartoes);
    const resultado = chaves.length;
    console.log(`🔍 [DEBUG] É objeto com ${resultado} chaves:`, chaves);
    return resultado;
  }
  
  console.log(`🔍 [DEBUG] Tipo não reconhecido, retornando 0`);
  return 0;
}

function atualizarDashboard(){
  let totalGols=0,totalAmarelos=0,totalVermelhos=0,totalFaltas=0,partidasJogadas=0;
  console.log('🔍 Atualizando dashboard - LÓGICA REFEITA...');
  
  dados.partidas.forEach((p,index)=>{
    console.log(`\n📋 === PARTIDA ${index}: ${p.mandante} vs ${p.visitante} ===`);
    
    // Contagem com nova função
    const amarelosMandante = contarCartoesSimples(p.discMandante, 'amarelos');
    const amarelosVisitante = contarCartoesSimples(p.discVisitante, 'amarelos');
    const vermelhosMandante = contarCartoesSimples(p.discMandante, 'vermelhos');
    const vermelhosVisitante = contarCartoesSimples(p.discVisitante, 'vermelhos');
    
    console.log(`🟨 Amarelos - Mandante: ${amarelosMandante}, Visitante: ${amarelosVisitante}`);
    console.log(`🟥 Vermelhos - Mandante: ${vermelhosMandante}, Visitante: ${vermelhosVisitante}`);
    
    // Conta TODAS as partidas e gols, independente do status
    totalGols+=(p.golsMandante||0)+(p.golsVisitante||0);
    partidasJogadas++;
    
    totalAmarelos += amarelosMandante + amarelosVisitante;
    totalVermelhos += vermelhosMandante + vermelhosVisitante;
    totalFaltas   +=(p.discMandante?.faltasC||0)+(p.discVisitante?.faltasC||0);
  });
  
  console.log(`\n📊 === RESUMO FINAL ===`);
  console.log(`📊 Amarelos: ${totalAmarelos}`);
  console.log(`📊 Vermelhos: ${totalVermelhos}`);
  console.log(`📊 Gols: ${totalGols}`);
  console.log(`📊 Partidas: ${partidasJogadas}`);
  document.getElementById('dashGols').textContent     =totalGols;
  document.getElementById('dashPartidas').textContent =partidasJogadas;
  document.getElementById('dashAmarelos').textContent =totalAmarelos;
  document.getElementById('dashVermelhos').textContent=totalVermelhos;

  if(dados.times.length>0){
    dados.times.forEach(calcTime);
    const sorted=[...dados.times].sort((a,b)=>b.pts-a.pts||b.sg-a.sg||b.gm-a.gm||b.v-a.v);
    document.getElementById('dashLider').textContent=sorted[0].nome;
  }
}

/* ================================================================
   SALVAR / CARREGAR
================================================================ */
function salvarLocal(){
  try{
    const n=document.getElementById('campeonatoNome');
    if(n)  dados.campeonato=n.textContent.trim()||dados.campeonato;
    localStorage.setItem('futebolEscolar',JSON.stringify(dados));
  }catch(e){console.error('Erro ao salvar:',e);}
}

function carregarLocal(){
  try{
    const raw=localStorage.getItem('futebolEscolar');
    if(raw){
      const d=JSON.parse(raw);
      dados=Object.assign({},dados,d);
      if(!Array.isArray(dados.times))     dados.times=[];
      if(!Array.isArray(dados.jogadores)) dados.jogadores=[];
      if(!Array.isArray(dados.partidas))  dados.partidas=[];
      if(!Array.isArray(dados.premios))   dados.premios=[];
      dados.partidas.forEach(p=>{
        const defStats={chutesGol:0,escanteios:0,golsPerdidos:0};
        const defDisc={faltasC:0,faltasS:0,amarelos:[],vermelhos:[],punicoes:'',reclamacoes:0,comportamento:'Ótimo',obs:''};
        if(!p.statsMandante)  p.statsMandante =Object.assign({},defStats);
        if(!p.statsVisitante) p.statsVisitante=Object.assign({},defStats);
        if(!p.discMandante)   p.discMandante  =Object.assign({},defDisc);
        if(!p.discVisitante)  p.discVisitante =Object.assign({},defDisc);
        ['amarelos','vermelhos'].forEach(k=>{
          if(!Array.isArray(p.discMandante[k]))  p.discMandante[k]=[];
          if(!Array.isArray(p.discVisitante[k])) p.discVisitante[k]=[];
        });
      });
      if(dados.times.length)     nextTimeId =Math.max(...dados.times.map(t=>t.id),0)+1;
      if(dados.jogadores.length) nextJogId  =Math.max(...dados.jogadores.map(j=>j.id),0)+1;
      if(dados.partidas.length)  nextPartId =Math.max(...dados.partidas.map(p=>p.id),0)+1;
      const el=document.getElementById('campeonatoNome');
      if(el) el.textContent=dados.campeonato||'INTERCLASSE SESI 2026';
      
      // Recalcula classificação após carregar dados do localStorage
      recalcularClassificacaoPorPartidas();
    }

    // Carrega tema salvo
    const temaSalvo = localStorage.getItem('temaAtual');
    if(temaSalvo && TEMA_VARS[temaSalvo]){
      aplicarTema(temaSalvo);
    } else {
      aplicarTema('default');
    }
    
    // Tamanho de fonte salvo
    const fonteSalva = localStorage.getItem('tamanhoFonte');
    if (fonteSalva) {
      aplicarTamanhoFonte(fonteSalva);
    }
    
    // Inicializa sistema de formato de partidas
    initPartidaFormat();
  }catch(e){console.error('Erro ao carregar:',e);}
}
