function calcularEstatisticasTime(nomeTime){
  let estatisticas = {
    partidasJogadas: 0,
    golsMarcados: 0,
    golsSofridos: 0,
    saldoGols: 0,
    chutesGol: 0,
    escanteios: 0,
    golsPerdidos: 0,
    cartoesAmarelos: 0,
    cartoesVermelhos: 0,
    faltasCometidas: 0,
    faltasSofridas: 0
  };
  
  console.log(`🏆 [DEBUG] Calculando estatísticas para: ${nomeTime}`);
  
  dados.partidas.forEach(partida => {
    if(partida.mandante === nomeTime || partida.visitante === nomeTime){
      if(partida.status === 'Encerrado' || partida.status === 'Ao Vivo'){
        estatisticas.partidasJogadas++;
        
        if(partida.mandante === nomeTime){
          estatisticas.golsMarcados += partida.golsMandante || 0;
          estatisticas.golsSofridos += partida.golsVisitante || 0;
          
          estatisticas.chutesGol += partida.statsMandante?.chutesGol || 0;
          estatisticas.escanteios += partida.statsMandante?.escanteios || 0;
          estatisticas.golsPerdidos += partida.statsMandante?.golsPerdidos || 0;
          
          // Usando nova função de contagem
          estatisticas.cartoesAmarelos += contarCartoesSimples(partida.discMandante, 'amarelos');
          estatisticas.cartoesVermelhos += contarCartoesSimples(partida.discMandante, 'vermelhos');
          estatisticas.faltasCometidas += partida.discMandante?.faltasC || 0;
          estatisticas.faltasSofridas += partida.discMandante?.faltasS || 0;
        } else {
          estatisticas.golsMarcados += partida.golsVisitante || 0;
          estatisticas.golsSofridos += partida.golsMandante || 0;
          
          estatisticas.chutesGol += partida.statsVisitante?.chutesGol || 0;
          estatisticas.escanteios += partida.statsVisitante?.escanteios || 0;
          estatisticas.golsPerdidos += partida.statsVisitante?.golsPerdidos || 0;
          
          // Usando nova função de contagem
          estatisticas.cartoesAmarelos += contarCartoesSimples(partida.discVisitante, 'amarelos');
          estatisticas.cartoesVermelhos += contarCartoesSimples(partida.discVisitante, 'vermelhos');
          estatisticas.faltasCometidas += partida.discVisitante?.faltasC || 0;
          estatisticas.faltasSofridas += partida.discVisitante?.faltasS || 0;
        }
      }
    }
  });
  
  estatisticas.saldoGols = estatisticas.golsMarcados - estatisticas.golsSofridos;
  
  console.log(`🏆 [DEBUG] Estatísticas finais para ${nomeTime}:`, estatisticas);
  
  return estatisticas;
}

