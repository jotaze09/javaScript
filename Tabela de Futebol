function updDiscCards(id,side,key,val){
  const p=dados.partidas.find(x=>x.id===id);
  if(!p) return;
  
  const txt=val.trim();
  if(!txt||txt==='Nenhum'){p[side][key]=[];}
  else{
    p[side][key]=txt.split(';').map(s=>{
      const m=s.trim().match(/^(.+?)\s*\((.+?)\)\s*$/);
      return m?{jogador:m[1].trim(),motivo:m[2].trim()}:{jogador:s.trim(),motivo:''};
    });
  }
  console.log(`🟥 Atualizando cartões partida ${id} [${side}]: ${key} = ${txt}`);
  console.log(`🔍 Estrutura final de cartões:`, p[side][key]);
  
  atualizarDashboard();
  renderTimes(); // Atualização automática da aba Times
  salvarLocal();
}

