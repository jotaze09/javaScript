function resetarDados() {
  if (!confirm('⚠️ ATENÇÃO: Esta ação apagará TODOS os dados (times, partidas, classificações, fotos).\n\nO tema escolhido será mantido.\n\nDeseja continuar?')) {
    return;
  }
  
  if (!confirm('🔴 ÚLTIMA CHANCE: Tem certeza absoluta que deseja resetar todos os dados?\n\nEsta ação não pode ser desfeita!')) {
    return;
  }
  
  // Salva o tema atual
  const temaSalvo = localStorage.getItem('temaAtual');
  const partidaFormatSalvo = localStorage.getItem('partidaFormat');
  
  // Limpa todo o localStorage
  localStorage.clear();
  
  // Restaura o tema
  if (temaSalvo) {
    localStorage.setItem('temaAtual', temaSalvo);
  }
  if (partidaFormatSalvo) {
    localStorage.setItem('partidaFormat', partidaFormatSalvo);
  }
  
  console.log('🔄 Todos os dados foram resetados. Tema mantido:', temaSalvo);
  
  // Recarrega a página
  location.reload();
}

